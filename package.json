{
  "name": "brittain-code",
  "productName": "Brittain Code",
  "version": "1.3.15",
  "description": "Local-first coding agent for Ollama with optional online research",
  "author": "Luke Brittain",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "test": "node --test",
    "dist": "electron-builder --mac dmg zip",
    "deploy": "electron-builder --mac dir && rm -rf '/Applications/Brittain Code.app' && cp -R 'dist/mac-arm64/Brittain Code.app' /Applications/ && echo 'Deployed to /Applications'",
    "dist:win": "electron-builder --win --x64",
    "dist:all": "electron-builder --mac dmg zip --win --x64"
  },
  "build": {
    "appId": "com.brittain.code",
    "productName": "Brittain Code",
    "files": [
      "main.js",
      "settings.js",
      "attachments.js",
      "ollama-recovery.js",
      "tools.js",
      "mcp.js",
      "preload.js",
      "renderer/**"
    ],
    "asarUnpack": [
      "node_modules/unpdf/**"
    ],
    "mac": {
      "identity": null,
      "target": [
        "dir",
        "dmg",
        "zip"
      ],
      "icon": "build/icon.icns"
    },
    "afterSign": "scripts/afterSign.js",
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon-1024.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "devDependencies": {
    "dompurify": "^3.4.11",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3",
    "marked": "^18.0.5"
  },
  "dependencies": {
    "unpdf": "^1.6.2"
  }
}
